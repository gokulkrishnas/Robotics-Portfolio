---
const projects = [
  {
    id: 'amr',
    image: '/robots/amr-demo.png',
    featured: true,
    label: 'Featured · Published Research',
    title: 'Autonomous Indoor Delivery Robot',
    description: 'Developed an autonomous indoor delivery robot using ROS and the TEB planner for precise path planning. Integrated advanced sensor fusion combining Lidar, wheel encoder odometry, and 9DOF IMU data via an Extended Kalman Filter to achieve high-accuracy localisation. Designed an intuitive PyQT-based GUI for user navigation and implemented voice-command functionality. Delivered as a fully functional, production-grade system.',
    date: 'Jun \'23',
    tags: ['ROS', 'TEB Planner', 'EKF', 'Lidar', 'IMU', 'PyQT', 'NVIDIA Jetson Nano'],
    links: { paper: 'https://link.springer.com/chapter/10.1007/978-981-97-6732-8_3', moreInfo: '#' },
    accent: 'cyan',
  },
  {
    id: 'docking',
    image: '/robots/docking-demo.png',
    featured: true,
    label: 'Featured · Robotics',
    title: 'Autonomous Docking System for Charging',
    description: 'Engineered an autonomous docking robot capable of aligning with a charging station using computer vision and Aruco markers. Designed a control algorithm in ROS by transforming camera and marker frames into feedback for precise motion commands. Demonstrated efficient and reliable performance in autonomous docking.',
    date: 'Jul \'22',
    tags: ['ROS', 'Computer Vision', 'Aruco Markers', 'Control Systems', 'Python'],
    links: { moreInfo: '#' },
    accent: 'cyan',
  },
  {
    id: 'marathon',
    featured: false,
    label: 'Cloud · Full Stack',
    title: 'Intelligent Marathon Pace Prediction Platform',
    description: 'Scalable web application delivering personalised marathon pacing recommendations combining performance modelling, course elevation analysis, and weather-aware adjustments. Docker microservices with NGINX gateway and AWS RDS PostgreSQL.',
    tags: ['Python', 'Docker', 'AWS RDS', 'NGINX', 'REST API'],
    links: { github: 'https://github.com/gokulkrishnas' },
    accent: 'indigo',
  },
  {
    id: 'fraud',
    featured: false,
    label: 'Machine Learning',
    title: 'Fraud Detection System',
    description: 'Real-time fraud detection pipeline trained on 6.3M+ financial transactions. Applied class balancing, feature engineering, and logistic regression to address extreme data imbalance (0.13% fraud cases). Achieved 95% accuracy and 94% recall.',
    tags: ['Python', 'Scikit-learn', 'Streamlit', 'Pandas', 'Logistic Regression'],
    links: { github: 'https://github.com/gokulkrishnas/Fraud-Detection-System' },
    accent: 'indigo',
  },
  {
    id: 'spacex',
    featured: false,
    label: 'Machine Learning',
    title: 'SpaceX Launch Success Prediction',
    description: 'ML pipeline to predict Falcon 9 first stage landing success. Trained and tuned Logistic Regression, SVM, KNN, and Decision Tree via Grid Search. Decision Tree achieved 94.4% accuracy.',
    tags: ['Python', 'Scikit-learn', 'Dash', 'Plotly', 'SQLite'],
    links: { github: 'https://github.com/gokulkrishnas/SpaceX-Launch-Success-Prediction' },
    accent: 'indigo',
  },
  {
    id: 'auto-sales',
    featured: false,
    label: 'Data Visualisation',
    title: 'Historical Automobile Sales Dashboard',
    description: 'Python-based interactive dashboard analysing automobile sales during recession periods. Deployed with Plotly Dash for rich, real-time visual exploration.',
    tags: ['Python', 'Dash', 'Plotly', 'Data Analysis', 'HTML'],
    links: { github: 'https://github.com/gokulkrishnas/Historical-Automobile-Sales-Dashboard', demo: 'https://historical-automobile-sales-dashboard.onrender.com' },
    accent: 'cyan',
  },
  {
    id: 'wildfire',
    featured: false,
    label: 'Data Visualisation',
    title: 'Australia Wildfire Analysis Dashboard',
    description: 'Interactive dashboard analysing Australian wildfire data across different regions and time periods. Deployed as a Plotly Dash application.',
    tags: ['Python', 'Dash', 'Plotly', 'Data Analysis', 'HTML'],
    links: { github: 'https://github.com/gokulkrishnas/Australia-Wildfire-Analysis-Dashboard', demo: 'https://australia-wildfire-analysis-dashboard.onrender.com' },
    accent: 'cyan',
  },
  {
    id: 'rain',
    featured: false,
    label: 'Machine Learning',
    title: 'Rainfall Prediction Classifier',
    description: 'ML pipeline predicting next-day rainfall from historical Australian weather data. Applied feature engineering, class balancing, and hyperparameter tuning across multiple classifiers.',
    tags: ['Python', 'Scikit-learn', 'Classification', 'GridSearchCV'],
    links: { github: 'https://github.com/gokulkrishnas/Rainfall-Prediction-Classifier' },
    accent: 'indigo',
  },
  {
    id: 'house-sales',
    featured: false,
    label: 'Predictive Analytics',
    title: 'House Sales Predictive Analytics',
    description: 'ML model analysing King County, USA housing data to predict sale prices. Pipeline approach with feature selection, polynomial transforms, and model evaluation.',
    tags: ['Python', 'Scikit-learn', 'Regression', 'Pipeline'],
    links: { github: 'https://github.com/gokulkrishnas/House-Sales-Analysis-USA' },
    accent: 'indigo',
  },
  {
    id: 'car-price',
    featured: false,
    label: 'Predictive Analytics',
    title: 'Car Price Predictive Analytics',
    description: 'ML model predicting car prices from vehicle specifications using regression pipelines, feature engineering, and rigorous model evaluation.',
    tags: ['Python', 'Scikit-learn', 'Regression', 'Pipeline'],
    links: { github: 'https://github.com/gokulkrishnas/Car-Price-Predictive-Analysis' },
    accent: 'indigo',
  },
  {
    id: 'cuisine',
    featured: false,
    label: 'Machine Learning',
    title: 'Cuisine Predictive Analytics',
    description: 'Classifies cuisine type from ingredient lists using predictive ML models. Part of the IBM Data Science Professional Certificate capstone series.',
    tags: ['Python', 'Scikit-learn', 'Pandas', 'Numpy', 'Classification'],
    links: { github: 'https://github.com/gokulkrishnas/Data-Science-Professional-IBM-Projects' },
    accent: 'purple',
  },
  {
    id: 'text-analytics',
    featured: false,
    label: 'Cloud · Event-Driven',
    title: 'Event-Driven Text Analytics Platform',
    description: 'Cloud-based text analytics application with event-driven architecture using AWS EC2, S3, and Lambda, enabling parallel multi-file processing and structured result storage.',
    tags: ['AWS', 'Lambda', 'S3', 'EC2', 'Python'],
    links: { github: 'https://github.com/gokulkrishnas' },
    accent: 'indigo',
  },
  {
    id: 'ecommerce',
    featured: false,
    label: 'Analytics · BI',
    title: 'E-Commerce Behavioural Analytics',
    description: 'SQL-based analysis on large-scale e-commerce datasets with interactive Looker Studio dashboards backed by Google BigQuery. FastAPI services deployed on Google Cloud Run.',
    tags: ['SQL', 'BigQuery', 'Looker Studio', 'FastAPI', 'GCP'],
    links: { github: 'https://github.com/gokulkrishnas' },
    accent: 'purple',
  },
  {
    id: 'llm',
    featured: false,
    label: 'GenAI · LLM',
    title: 'OLLAMA Chatbot',
    description: 'Lightweight LLM-powered chatbot using OLLAMA and GROQ with context-aware, low-latency responses. Implemented prompt engineering, text embeddings, and memory context management.',
    tags: ['Ollama LLM', 'Groq', 'AI Integration', 'LLM Deployment'],
    links: { demo: 'https://gokulkrishna-portfolio.streamlit.app/chatbot' },
    accent: 'purple',
  },
  {
    id: 'research-paper',
    featured: false,
    label: 'GenAI · NLP',
    title: 'Research Paper Summarizer',
    description: 'OpenAI-powered RAG application that ingests research papers and answers questions about their content using natural language.',
    tags: ['OpenAI', 'NLP', 'LLM', 'RAG'],
    links: { demo: 'https://gokulkrishna-portfolio.streamlit.app/document_summarizer' },
    accent: 'purple',
  },
  {
    id: 'resume-analyzer',
    featured: false,
    label: 'GenAI · NLP',
    title: 'Resume Analyzer',
    description: 'OpenAI-powered resume analyzer that assesses and refines resumes to align with specific job descriptions using Chroma DB for vector search.',
    tags: ['OpenAI', 'Chroma DB', 'RAG', 'NLP'],
    links: { github: 'https://github.com/gokulkrishnas/Resume_Analyser', demo: 'https://gokulkrishna-portfolio.streamlit.app/resume_analyser' },
    accent: 'purple',
  },
  {
    id: 'iris',
    featured: false,
    label: 'Machine Learning',
    title: 'Iris Flower Predictor',
    description: 'Iris species classifier using ML to predict flower species from petal and sepal measurements, deployed as an interactive Streamlit app.',
    tags: ['Python', 'Scikit-learn', 'Streamlit', 'Classification'],
    links: { github: 'https://github.com/gokulkrishnas/Iris_Prediction_Streamlit', demo: 'https://gokulkrishna-portfolio.streamlit.app/iris_predictor' },
    accent: 'cyan',
  },
];
---

<section id="projects" class="section">
  <div class="glow-orb glow-purple" style="width:400px;height:400px;top:20%;left:-100px;"></div>

  <div class="container">
    <div class="projects-header reveal">
      <p class="section-label">02 — Projects</p>
      <h2 class="section-title">
        Things I've <span class="gradient-text">built</span>
      </h2>
      <p class="projects-sub">
        Ranging from published robotics research to cloud-native data platforms.
      </p>
    </div>

    <!-- Featured projects -->
    {projects.filter(p => p.featured).map((p, fi) => (
      <div class={`featured-card reveal${fi > 0 ? ' reveal-delay-1' : ''}`}>
        <div class="featured-badge-row">
          <div class="featured-badge font-mono">★ {p.label}</div>
          {p.date && <span class="featured-date font-mono">{p.date}</span>}
        </div>

        <div class="featured-inner">
          <div class="featured-text">
            <h3 class="featured-title">{p.title}</h3>
            <p class="featured-desc">{p.description}</p>

            <div class="tag-row">
              {p.tags.map(tag => <span class="skill-tag">{tag}</span>)}
            </div>

            <div class="card-links">
              {p.links.paper && (
                <div class="glass-btn-wrap">
                  <a href={p.links.paper} target="_blank" rel="noopener" class="glass-btn">
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M14 2H6a2 2 0 00-2 2v16a2 2 0 002 2h12a2 2 0 002-2V8z"/><polyline points="14 2 14 8 20 8"/>
                    </svg>
                    Read Paper
                  </a>
                  <div class="glass-btn-shadow"></div>
                </div>
              )}
              {p.links.moreInfo && (
                <div class="glass-btn-wrap">
                  <a href={p.links.moreInfo} class="glass-btn">
                    More Info
                    <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M5 12h14M12 5l7 7-7 7"/>
                    </svg>
                  </a>
                  <div class="glass-btn-shadow"></div>
                </div>
              )}
            </div>
          </div>

          <!-- Project visual -->
          <div class="featured-visual">
            <img
              src={p.image ?? `/robots/${p.id}-demo.jpg`}
              alt={p.title}
              class="featured-demo-img"
              onerror={`this.style.display='none';document.getElementById('fallback-${p.id}').style.display='flex'`}
            />
            <div id={`fallback-${p.id}`} class="visual-placeholder" style="display:none">
              <svg width="48" height="48" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" opacity="0.3">
                <circle cx="12" cy="12" r="3"/>
                <path d="M12 2v2M12 20v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M2 12h2M20 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/>
              </svg>
              <span class="font-mono" style="font-size:11px;color:var(--text-muted)">demo · coming soon</span>
            </div>
          </div>
        </div>
      </div>
    ))}

    <!-- Show More button -->
    <div class="show-more-wrap reveal">
      <div class="glass-btn-wrap">
        <button class="glass-btn" id="show-more-btn">
          Show More Projects
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="glass-btn-shadow"></div>
      </div>
    </div>
  </div>
</section>

<!-- Projects modal -->
<div class="projects-modal" id="projects-modal" aria-hidden="true">
  <div class="projects-modal-backdrop" id="modal-backdrop"></div>
  <div class="projects-modal-panel">
    <div class="modal-header">
      <h3 class="modal-title">More Projects</h3>
      <button class="modal-close" id="modal-close" aria-label="Close">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="projects-grid">
      {projects.filter(p => !p.featured).map((p, i) => (
        <div class={`card project-card`}>
          <div class="card-header">
            <span class={`card-label font-mono accent-${p.accent}`}>{p.label}</span>
            <div class="card-link-icons">
              {p.links.github && (
                <a href={p.links.github} target="_blank" rel="noopener" class="icon-link" aria-label="GitHub">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.37.6.1.82-.26.82-.58v-2.03c-3.34.72-4.04-1.61-4.04-1.61-.54-1.38-1.33-1.75-1.33-1.75-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.23 1.84 1.23 1.07 1.84 2.81 1.3 3.5 1 .1-.78.42-1.3.76-1.6-2.66-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 013-.4c1.02 0 2.04.13 3 .4 2.28-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58C20.57 21.8 24 17.3 24 12 24 5.37 18.63 0 12 0z"/>
                  </svg>
                </a>
              )}
              {p.links.demo && (
                <a href={p.links.demo} target="_blank" rel="noopener" class="icon-link" aria-label="Live Demo">
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M18 13v6a2 2 0 01-2 2H5a2 2 0 01-2-2V8a2 2 0 012-2h6M15 3h6v6M10 14L21 3"/>
                  </svg>
                </a>
              )}
            </div>
          </div>
          <h3 class="card-title">{p.title}</h3>
          <p class="card-desc">{p.description}</p>
          <div class="tag-row">
            {p.tags.slice(0, 4).map(tag => <span class="skill-tag">{tag}</span>)}
            {p.tags.length > 4 && <span class="skill-tag">+{p.tags.length - 4}</span>}
          </div>
        </div>
      ))}
    </div>
  </div>
</div>

<style>
  .projects-header { margin-bottom: 56px; }

  .projects-sub {
    color: var(--text-muted);
    font-size: 15px;
    margin-top: 8px;
    max-width: 480px;
  }

  /* ── Featured card ────────────────────────────────────────── */
  .featured-card {
    background: linear-gradient(145deg, rgba(255,255,255,0.9), rgba(255,255,255,0.7));
    backdrop-filter: blur(24px) saturate(1.8);
    -webkit-backdrop-filter: blur(24px) saturate(1.8);
    border: 1px solid rgba(0,0,0,0.06);
    border-radius: var(--radius-lg);
    padding: 36px;
    margin-bottom: 40px;
    box-shadow: var(--shadow-md), inset 0 1px 0 rgba(255,255,255,1);
    position: relative;
    overflow: hidden;
  }

  .featured-card::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    height: 2px;
    background: linear-gradient(90deg, var(--accent), rgba(0,113,227,0.4));
  }

  .featured-badge-row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 20px;
  }

  .featured-badge {
    font-size: 11px;
    color: var(--accent);
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .featured-date {
    font-size: 11px;
    color: var(--text-muted);
    letter-spacing: 0.08em;
  }

  .featured-inner {
    display: grid;
    grid-template-columns: 1.4fr 1fr;
    gap: 48px;
    align-items: center;
  }

  .featured-title {
    font-size: 1.6rem;
    font-weight: 700;
    color: var(--text-primary);
    margin-bottom: 16px;
    letter-spacing: -0.02em;
  }

  .featured-desc {
    color: var(--text-secondary);
    line-height: 1.75;
    font-size: 15px;
    margin-bottom: 24px;
  }

  .featured-visual {
    height: 260px;
    background: var(--bg-base);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .featured-demo-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s ease;
  }
  .featured-demo-img:hover { transform: scale(1.04); }

  .visual-placeholder {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 12px;
  }

  /* ── Project grid ─────────────────────────────────────────── */
  .projects-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .project-card { display: flex; flex-direction: column; }

  .card-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 14px;
  }

  .card-label {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .accent-cyan   { color: var(--accent-cyan); }
  .accent-indigo { color: var(--accent-indigo); }
  .accent-purple { color: var(--accent-purple); }

  .card-link-icons { display: flex; gap: 8px; }

  .icon-link {
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .icon-link:hover { color: var(--accent); }

  .card-title {
    font-size: 1rem;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 10px;
    line-height: 1.3;
  }

  .card-desc {
    font-size: 13px;
    color: var(--text-secondary);
    line-height: 1.65;
    flex: 1;
    margin-bottom: 20px;
  }

  .tag-row {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }

  /* ── Links ────────────────────────────────────────────────── */
  .card-links { display: flex; gap: 10px; flex-wrap: wrap; margin-top: 28px; }

  /* ── Show More ────────────────────────────────────────────── */
  .show-more-wrap {
    display: flex;
    justify-content: center;
    margin-top: 40px;
  }

  /* ── Modal ────────────────────────────────────────────────── */
  .projects-modal {
    position: fixed;
    inset: 0;
    z-index: 300;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.3s ease;
  }
  .projects-modal.open {
    opacity: 1;
    pointer-events: all;
  }

  .projects-modal-backdrop {
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.4);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  .projects-modal-panel {
    position: relative;
    z-index: 1;
    width: min(960px, 94vw);
    max-height: 82vh;
    overflow-y: auto;
    background: linear-gradient(145deg, rgba(255,255,255,0.92), rgba(245,245,247,0.88));
    backdrop-filter: blur(32px) saturate(1.8);
    -webkit-backdrop-filter: blur(32px) saturate(1.8);
    border: 1px solid rgba(255,255,255,0.9);
    border-radius: var(--radius-xl);
    box-shadow: 0 24px 80px rgba(0,0,0,0.18), inset 0 1px 0 rgba(255,255,255,1);
    padding: 32px;
    transform: translateY(24px);
    transition: transform 0.35s cubic-bezier(0.25,1,0.5,1);
  }
  .projects-modal.open .projects-modal-panel {
    transform: translateY(0);
  }

  .modal-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 28px;
  }

  .modal-title {
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--text-primary);
    letter-spacing: -0.02em;
  }

  .modal-close {
    all: unset;
    cursor: pointer;
    width: 36px;
    height: 36px;
    border-radius: 50%;
    background: rgba(0,0,0,0.05);
    border: 1px solid rgba(0,0,0,0.08);
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--text-muted);
    transition: background 0.2s;
    pointer-events: auto;
  }
  .modal-close:hover { background: rgba(0,0,0,0.1); color: var(--text-primary); }

  /* ── Responsive ───────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .projects-grid { grid-template-columns: repeat(2, 1fr); }
  }

  @media (max-width: 768px) {
    .projects-grid { grid-template-columns: 1fr; }
    .featured-inner { grid-template-columns: 1fr; }
    .featured-visual { display: none; }
    .projects-modal-panel { padding: 20px; }
  }
</style>

<script>
  const modal   = document.getElementById('projects-modal');
  const openBtn = document.getElementById('show-more-btn');
  const closeBtn = document.getElementById('modal-close');
  const backdrop = document.getElementById('modal-backdrop');

  function openModal() {
    modal?.classList.add('open');
    modal?.removeAttribute('aria-hidden');
    document.body.style.overflow = 'hidden';
  }
  function closeModal() {
    modal?.classList.remove('open');
    modal?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
</script>
