---
import SplineScene from '../SplineScene.astro';

/**
 * SPLINE: Replace the URL below with your actual export URL from Spline.
 * Scene: GENKUB — Greeting Robot
 * Steps: Open in Spline → Export → Web → Copy URL
 * Make sure Background is set to Transparent in scene settings.
 */
const GENKUB_URL  = 'https://prod.spline.design/URNWsSjOJHXK1sUs/scene.splinecode';
const HERO_BG_URL = 'https://prod.spline.design/8drWQPA7PfGR9fa7/scene.splinecode';
---

<section id="home" class="section hero-section bg-grid">
  <!-- Landing page Spline background -->
  <div class="hero-bg-spline" id="hero-bg-wrapper" aria-hidden="true">
    <canvas id="hero-bg-canvas" data-hero-bg={HERO_BG_URL}></canvas>
  </div>
  <!-- Mask the Spline watermark badge rendered inside the canvas -->
  <div class="spline-badge-mask" aria-hidden="true"></div>

  <!-- Subtle glow orbs beneath content -->
  <div class="glow-orb glow-cyan"   style="width:500px;height:500px;top:-100px;left:-100px;"></div>
  <div class="glow-orb glow-indigo" style="width:400px;height:400px;bottom:0;right:0;"></div>

  <div class="container hero-inner" style="position:relative;z-index:1;">
    <!-- Left: Text content -->
    <div class="hero-text">
      <h1 class="hero-name reveal">
        Gokulkrishna S
      </h1>

      <div class="hero-title-row reveal reveal-delay-2">
        <span class="title-tag">Robotics Engineer</span>
        <span class="title-separator">/</span>
        <span class="title-sub">Autonomous Systems</span>
      </div>

      <p class="hero-bio reveal reveal-delay-3">
        Building intelligent autonomous systems at the intersection of
        <span class="highlight">ROS</span>, <span class="highlight">embedded AI</span>, and
        <span class="highlight">machine learning</span>. MSc Data Science · University of Surrey.
        Co-author of a Springer Nature publication on indoor delivery robotics.
      </p>

      <div class="hero-ctas reveal reveal-delay-4">
        <a href="#projects" class="btn-primary">
          View Projects
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
        <a href="/cv.pdf" class="btn-secondary" target="_blank" rel="noopener">
          Download CV
          <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M21 15v4a2 2 0 01-2 2H5a2 2 0 01-2-2v-4M7 10l5 5 5-5M12 15V3"/>
          </svg>
        </a>
      </div>

      <!-- Social links -->
      <div class="hero-socials reveal reveal-delay-4">
        <a href="https://github.com/gokulkrishnas" target="_blank" rel="noopener" class="social-link" aria-label="GitHub">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.37.6.1.82-.26.82-.58v-2.03c-3.34.72-4.04-1.61-4.04-1.61-.54-1.38-1.33-1.75-1.33-1.75-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.23 1.84 1.23 1.07 1.84 2.81 1.3 3.5 1 .1-.78.42-1.3.76-1.6-2.66-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 013-.4c1.02 0 2.04.13 3 .4 2.28-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58C20.57 21.8 24 17.3 24 12 24 5.37 18.63 0 12 0z"/>
          </svg>
        </a>
        <a href="https://linkedin.com/in/gokulks01" target="_blank" rel="noopener" class="social-link" aria-label="LinkedIn">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor">
            <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 110-4.12 2.06 2.06 0 010 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46C23.2 24 24 23.23 24 22.28V1.72C24 .77 23.2 0 22.23 0z"/>
          </svg>
        </a>
        <a href="mailto:gokulkrishna30082001@gmail.com" class="social-link" aria-label="Email">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <rect x="2" y="4" width="20" height="16" rx="2"/>
            <path d="M22 7l-10 7L2 7"/>
          </svg>
        </a>
      </div>
    </div>

    <!-- Right: Robot — floats freely, no box -->
    <div class="hero-scene reveal reveal-delay-2">
      <SplineScene url={GENKUB_URL} height="520px" class="hero-robot-scene" />
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="scroll-hint">
    <div class="scroll-line"></div>
    <span class="font-mono">scroll</span>
  </div>
</section>

<style>
  .hero-section {
    min-height: 100svh;
    display: flex;
    align-items: center;
    padding-top: var(--navbar-h);
  }

  .hero-inner {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 64px;
    align-items: center;
  }

  /* ── Text ─────────────────────────────────────────────────── */
  .hero-label {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    font-size: 12px;
    color: var(--text-muted);
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 20px;
  }

  .label-dot {
    width: 8px;
    height: 8px;
    background: #22c55e;
    border-radius: 50%;
    box-shadow: 0 0 8px #22c55e;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.6; transform: scale(0.85); }
  }

  .hero-name {
    font-size: clamp(2.6rem, 5vw, 4rem);
    font-weight: 700;
    letter-spacing: -0.03em;
    line-height: 1.05;
    margin-bottom: 16px;
    color: var(--text-primary);
  }

  .hero-title-row {
    display: flex;
    align-items: center;
    gap: 12px;
    margin-bottom: 28px;
  }

  .title-tag {
    font-family: 'SF Mono', ui-monospace, monospace;
    font-size: 13px;
    color: var(--accent);
    background: rgba(0,113,227,0.08);
    border: 1px solid rgba(0,113,227,0.2);
    padding: 4px 12px;
    border-radius: 100px;
  }

  .title-separator { color: var(--text-muted); font-size: 16px; }

  .title-sub {
    font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif;
    font-size: 14px;
    color: var(--text-muted);
  }

  .hero-bio {
    font-size: 16px;
    line-height: 1.75;
    color: var(--text-secondary);
    max-width: 480px;
    margin-bottom: 36px;
  }

  .highlight {
    color: var(--accent);
    font-weight: 500;
  }

  .hero-ctas {
    display: flex;
    gap: 16px;
    flex-wrap: wrap;
    margin-bottom: 32px;
  }

  .hero-socials {
    display: flex;
    gap: 12px;
  }

  .social-link {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 40px;
    height: 40px;
    background: rgba(255,255,255,0.72);
    backdrop-filter: blur(20px);
    -webkit-backdrop-filter: blur(20px);
    border: 1px solid rgba(0,0,0,0.08);
    border-radius: 10px;
    color: var(--text-muted);
    text-decoration: none;
    transition: all 0.2s ease;
    box-shadow: 0 2px 8px rgba(0,0,0,0.06), inset 0 1px 0 rgba(255,255,255,1);
  }

  .social-link:hover {
    border-color: var(--border-accent);
    color: var(--accent);
    transform: translateY(-3px);
    box-shadow: 0 4px 16px rgba(0,113,227,0.15), inset 0 1px 0 rgba(255,255,255,1);
  }

  /* ── Background Spline scene ──────────────────────────────── */
  .hero-bg-spline {
    position: absolute;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 1.8s ease;
    overflow: hidden;
  }
  .hero-bg-spline.loaded { opacity: 0.28; }
  #hero-bg-canvas { width: 100%; height: 100%; display: block; }


  /* Mask watermark badge inside bg canvas */
  .spline-badge-mask {
    position: absolute;
    bottom: 0; right: 0;
    width: 210px; height: 56px;
    background: var(--bg-base);
    z-index: 10;
    pointer-events: none;
  }

  /* ── Robot scene — frameless ──────────────────────────────── */
  /* Clip container height to hide the badge row at the bottom of the canvas */
  .hero-scene {
    position: relative;
    overflow: hidden;
    height: 458px; /* 520px canvas - 62px badge row */
  }

  :global(.hero-robot-scene) {
    border-radius: 0 !important;
    background: transparent;
  }
  :global(.hero-robot-scene canvas) {
    border-radius: 0 !important;
    /* Soft radial fade to blend robot edges with background */
    -webkit-mask-image: radial-gradient(ellipse 92% 92% at 50% 46%, black 52%, transparent 100%);
    mask-image: radial-gradient(ellipse 92% 92% at 50% 46%, black 52%, transparent 100%);
  }
  /* No solid mask needed — container clips badge area */
  :global(.hero-robot-scene::after) {
    display: none !important;
  }

  /* ── Scroll hint ──────────────────────────────────────────── */
  .scroll-hint {
    position: absolute;
    bottom: 32px;
    left: 50%;
    transform: translateX(-50%);
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 8px;
    color: var(--text-muted);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    animation: scroll-bob 2s ease-in-out infinite;
  }

  .scroll-line {
    width: 1px;
    height: 36px;
    background: linear-gradient(180deg, var(--accent), transparent);
    animation: scroll-line-grow 2s ease-in-out infinite;
  }

  @keyframes scroll-bob {
    0%, 100% { transform: translateX(-50%) translateY(0); }
    50%       { transform: translateX(-50%) translateY(6px); }
  }

  @keyframes scroll-line-grow {
    0%, 100% { opacity: 0.8; }
    50%       { opacity: 0.3; }
  }

  /* ── Responsive ───────────────────────────────────────────── */
  @media (max-width: 900px) {
    .hero-inner {
      grid-template-columns: 1fr;
      gap: 48px;
      text-align: center;
    }

    .hero-label, .hero-title-row, .hero-ctas, .hero-socials {
      justify-content: center;
    }

    .hero-bio { margin: 0 auto 36px; }
    .scroll-hint { display: none; }
  }
</style>

<script>
  async function initHeroBg() {
    const canvas = document.getElementById('hero-bg-canvas') as HTMLCanvasElement | null;
    if (!canvas) return;
    const url = canvas.dataset.heroBg;
    if (!url) return;
    const wrapper = document.getElementById('hero-bg-wrapper');
    try {
      const { Application } = await import('@splinetool/runtime');
      const app = new Application(canvas);
      await app.load(url);
      wrapper?.classList.add('loaded');
    } catch {
      // Silently fall back to plain background
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initHeroBg);
  } else {
    initHeroBg();
  }
</script>
