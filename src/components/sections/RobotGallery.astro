---
/**
 * RobotGallery — infinite right-to-left auto-scrolling carousel.
 *
 * TO ADD IMAGES: Drop .jpg / .jpeg / .png / .webp files into
 *   src/assets/robots/
 * No code changes needed — images appear automatically.
 */
import type { ImageMetadata } from 'astro';

const modules = import.meta.glob<{ default: ImageMetadata }>(
  '/src/assets/robots/*.{jpg,jpeg,png,webp,JPG,JPEG,PNG,WEBP}',
  { eager: true }
);
const images: ImageMetadata[] = Object.values(modules).map(m => m.default);
const hasImages = images.length > 0;
---

{hasImages && (
<section id="gallery" class="section gallery-section">
  <div class="container">
    <div class="gallery-header reveal">
      <p class="section-label">Lab — Robots</p>
      <h2 class="section-title">Machines I've <span class="gradient-text">built</span></h2>
    </div>
  </div>

  <!-- Full-width scrolling carousel -->
  <div class="carousel-viewport">
    <div class="carousel-track">
      {/* Original set */}
      {images.map((img, i) => (
        <div class="carousel-slide">
          <img
            src={img.src}
            alt={`Robot ${i + 1}`}
            loading="lazy"
            class="carousel-img"
          />
        </div>
      ))}
      {/* Duplicate set — enables seamless loop */}
      {images.map((img, i) => (
        <div class="carousel-slide" aria-hidden="true">
          <img
            src={img.src}
            alt=""
            loading="lazy"
            class="carousel-img"
          />
        </div>
      ))}
    </div>
  </div>
</section>
)}

<style>
  .gallery-section { background: #ffffff; }
  .gallery-header  { margin-bottom: 40px; }

  /* ── Viewport — clips overflow, fades edges ─────────────────── */
  .carousel-viewport {
    width: 100%;
    overflow: hidden;
    position: relative;
  }

  .carousel-viewport::before,
  .carousel-viewport::after {
    content: '';
    position: absolute;
    top: 0; bottom: 0;
    width: 120px;
    z-index: 2;
    pointer-events: none;
  }
  .carousel-viewport::before {
    left: 0;
    background: linear-gradient(to right, #ffffff, transparent);
  }
  .carousel-viewport::after {
    right: 0;
    background: linear-gradient(to left, #ffffff, transparent);
  }

  /* ── Track — flex row, scrolls left continuously ───────────── */
  .carousel-track {
    display: flex;
    /* margin-right on each slide (not gap) so -50% is always exact */
    animation: scroll-left 28s linear infinite;
    width: max-content;
    will-change: transform;
  }

  /* Pause on hover */
  .carousel-track:hover { animation-play-state: paused; }

  /* ── Individual slide — uniform size ───────────────────────── */
  .carousel-slide {
    flex-shrink: 0;
    width: 320px;
    height: 230px;
    margin-right: 20px;
    border-radius: var(--radius);
    overflow: hidden;
    background: var(--bg-base);
    border: 1px solid rgba(0,0,0,0.06);
    box-shadow: var(--shadow-sm);
  }

  .carousel-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .carousel-slide:hover .carousel-img { transform: scale(1.04); }

  /* ── Keyframe — scroll by exactly 50% (original set width) ─── */
  @keyframes scroll-left {
    from { transform: translateX(0); }
    to   { transform: translateX(-50%); }
  }
</style>
