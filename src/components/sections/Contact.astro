---

const contactLinks = [
  {
    label: 'Email',
    value: 'gokulkrishna30082001@gmail.com',
    href:  'mailto:gokulkrishna30082001@gmail.com',
    icon:  'email',
    accent: 'cyan',
  },
  {
    label: 'LinkedIn',
    value: 'linkedin.com/in/gokulks01',
    href:  'https://linkedin.com/in/gokulks01',
    icon:  'linkedin',
    accent: 'indigo',
  },
  {
    label: 'GitHub',
    value: 'github.com/gokulkrishnas',
    href:  'https://github.com/gokulkrishnas',
    icon:  'github',
    accent: 'purple',
  },
];
---

<section id="contact" class="section">
  <div class="glow-orb glow-cyan"   style="width:400px;height:400px;top:0;left:-80px;"></div>
  <div class="glow-orb glow-purple" style="width:350px;height:350px;bottom:0;right:-60px;"></div>

  <div class="container">
    <div class="contact-header reveal">
      <p class="section-label">06 — Contact</p>
      <h2 class="section-title">Let's <span class="gradient-text">connect</span></h2>
      <p class="contact-sub">
        Open to robotics engineering roles, research collaborations, and exciting autonomous systems projects.
      </p>
    </div>

    <div class="contact-links-wrap">
      <div class="contact-links-col">
        {contactLinks.map((link, i) => (
          <a href={link.href} target={link.href.startsWith('mailto') ? undefined : '_blank'} rel="noopener" class={`contact-card card reveal reveal-delay-${i + 1}`}>
            <div class={`contact-icon-wrap accent-bg-${link.accent}`}>
              {link.icon === 'email' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class={`accent-${link.accent}`}>
                  <rect x="2" y="4" width="20" height="16" rx="2"/><path d="M22 7l-10 7L2 7"/>
                </svg>
              )}
              {link.icon === 'linkedin' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class={`accent-${link.accent}`}>
                  <path d="M20.45 20.45h-3.55v-5.57c0-1.33-.03-3.04-1.85-3.04-1.86 0-2.14 1.45-2.14 2.95v5.66H9.36V9h3.41v1.56h.05c.48-.9 1.64-1.85 3.37-1.85 3.6 0 4.27 2.37 4.27 5.45v6.29zM5.34 7.43a2.06 2.06 0 110-4.12 2.06 2.06 0 010 4.12zM7.12 20.45H3.56V9h3.56v11.45zM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46C23.2 24 24 23.23 24 22.28V1.72C24 .77 23.2 0 22.23 0z"/>
                </svg>
              )}
              {link.icon === 'github' && (
                <svg width="20" height="20" viewBox="0 0 24 24" fill="currentColor" class={`accent-${link.accent}`}>
                  <path d="M12 0C5.37 0 0 5.37 0 12c0 5.3 3.44 9.8 8.2 11.37.6.1.82-.26.82-.58v-2.03c-3.34.72-4.04-1.61-4.04-1.61-.54-1.38-1.33-1.75-1.33-1.75-1.09-.74.08-.73.08-.73 1.2.08 1.84 1.23 1.84 1.23 1.07 1.84 2.81 1.3 3.5 1 .1-.78.42-1.3.76-1.6-2.66-.3-5.47-1.33-5.47-5.93 0-1.31.47-2.38 1.24-3.22-.14-.3-.54-1.52.11-3.18 0 0 1.01-.32 3.3 1.23a11.5 11.5 0 013-.4c1.02 0 2.04.13 3 .4 2.28-1.55 3.3-1.23 3.3-1.23.65 1.66.24 2.88.12 3.18.77.84 1.23 1.91 1.23 3.22 0 4.61-2.81 5.63-5.48 5.92.43.37.81 1.1.81 2.22v3.29c0 .32.22.7.83.58C20.57 21.8 24 17.3 24 12 24 5.37 18.63 0 12 0z"/>
                </svg>
              )}
            </div>
            <div class="contact-text">
              <span class={`contact-label-text font-mono accent-${link.accent}`}>{link.label}</span>
              <span class="contact-value">{link.value}</span>
            </div>
            <svg class="contact-arrow" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M5 12h14M12 5l7 7-7 7"/>
            </svg>
          </a>
        ))}

        <!-- Location -->
        <div class="location-note reveal reveal-delay-4">
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" style="color:var(--text-muted)">
            <path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0118 0z"/><circle cx="12" cy="10" r="3"/>
          </svg>
          <span>Guildford, UK · Open to relocation</span>
        </div>
      </div>

      <!-- Pixel art robot -->
      <div class="contact-art reveal">
        <svg class="pixel-robot" viewBox="0 0 80 100" xmlns="http://www.w3.org/2000/svg" style="image-rendering:pixelated">
          <!-- Antenna -->
          <rect x="38" y="2" width="4" height="8" fill="currentColor" opacity="0.5"/>
          <rect x="34" y="8" width="12" height="4" fill="currentColor" opacity="0.5"/>
          <!-- Head -->
          <rect x="20" y="14" width="40" height="32" rx="2" fill="currentColor" opacity="0.12"/>
          <rect x="22" y="16" width="36" height="28" rx="1" fill="currentColor" opacity="0.08"/>
          <!-- Eyes -->
          <rect x="28" y="22" width="8" height="8" rx="1" fill="currentColor" opacity="0.55"/>
          <rect x="44" y="22" width="8" height="8" rx="1" fill="currentColor" opacity="0.55"/>
          <!-- Eye shine -->
          <rect x="30" y="24" width="2" height="2" fill="white" opacity="0.8"/>
          <rect x="46" y="24" width="2" height="2" fill="white" opacity="0.8"/>
          <!-- Mouth -->
          <rect x="28" y="34" width="4" height="4" rx="1" fill="currentColor" opacity="0.35"/>
          <rect x="34" y="36" width="12" height="2" fill="currentColor" opacity="0.35"/>
          <rect x="48" y="34" width="4" height="4" rx="1" fill="currentColor" opacity="0.35"/>
          <!-- Neck -->
          <rect x="34" y="46" width="12" height="6" fill="currentColor" opacity="0.3"/>
          <!-- Body -->
          <rect x="16" y="52" width="48" height="32" rx="3" fill="currentColor" opacity="0.1"/>
          <rect x="18" y="54" width="44" height="28" rx="2" fill="currentColor" opacity="0.08"/>
          <!-- Chest panel -->
          <rect x="28" y="58" width="24" height="16" rx="2" fill="currentColor" opacity="0.2"/>
          <rect x="30" y="60" width="8" height="5" rx="1" fill="currentColor" opacity="0.4"/>
          <rect x="42" y="60" width="8" height="5" rx="1" fill="currentColor" opacity="0.4"/>
          <rect x="30" y="67" width="20" height="3" rx="1" fill="currentColor" opacity="0.3"/>
          <!-- Arms -->
          <rect x="4" y="52" width="10" height="24" rx="2" fill="currentColor" opacity="0.12"/>
          <rect x="66" y="52" width="10" height="24" rx="2" fill="currentColor" opacity="0.12"/>
          <!-- Hands -->
          <rect x="2" y="74" width="14" height="8" rx="2" fill="currentColor" opacity="0.18"/>
          <rect x="64" y="74" width="14" height="8" rx="2" fill="currentColor" opacity="0.18"/>
          <!-- Legs -->
          <rect x="24" y="84" width="12" height="14" rx="2" fill="currentColor" opacity="0.14"/>
          <rect x="44" y="84" width="12" height="14" rx="2" fill="currentColor" opacity="0.14"/>
          <!-- Feet -->
          <rect x="22" y="96" width="16" height="4" rx="1" fill="currentColor" opacity="0.2"/>
          <rect x="42" y="96" width="16" height="4" rx="1" fill="currentColor" opacity="0.2"/>
        </svg>
        <p class="art-label font-mono">available · open to work</p>
      </div>
    </div>

    <!-- Footer -->
    <footer class="footer reveal">
      <p class="font-mono">
        Built with <span style="color:var(--accent-cyan)">Astro</span> ·
        Designed by Gokulkrishna S ·
        <span style="color:var(--text-muted)">{new Date().getFullYear()}</span>
      </p>
    </footer>
  </div>
</section>

<style>
  .contact-header { margin-bottom: 56px; }

  .contact-sub {
    font-size: 15px;
    color: var(--text-muted);
    max-width: 480px;
    line-height: 1.6;
    margin-top: 8px;
  }

  .contact-links-wrap {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 64px;
    margin-bottom: 80px;
  }

  /* ── Contact cards ────────────────────────────────────────── */
  .contact-links-col {
    display: flex;
    flex-direction: column;
    gap: 14px;
    width: 100%;
    max-width: 480px;
  }

  /* ── Pixel art panel ──────────────────────────────────────── */
  .contact-art {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    flex-shrink: 0;
  }

  .pixel-robot {
    width: 120px;
    height: 150px;
    color: var(--accent);
    opacity: 0.7;
    animation: pixel-float 4s ease-in-out infinite;
  }

  @keyframes pixel-float {
    0%, 100% { transform: translateY(0); }
    50%       { transform: translateY(-10px); }
  }

  .art-label {
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--text-muted);
  }

  .contact-card {
    display: flex;
    align-items: center;
    gap: 18px;
    padding: 20px 24px;
    text-decoration: none;
    transition: all 0.25s ease;
  }

  .contact-card:hover {
    transform: translateX(6px);
  }

  .contact-icon-wrap {
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .accent-bg-cyan   { background: rgba(0,113,227,0.06);   border: 1px solid rgba(0,113,227,0.18); }
  .accent-bg-indigo { background: rgba(0,113,227,0.05);   border: 1px solid rgba(0,113,227,0.15); }
  .accent-bg-purple { background: rgba(110,110,115,0.06); border: 1px solid rgba(110,110,115,0.18); }

  .contact-text { flex: 1; display: flex; flex-direction: column; gap: 3px; }

  .contact-label-text {
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
  }

  .contact-value {
    font-size: 14px;
    color: var(--text-primary);
  }

  .contact-arrow {
    color: var(--text-muted);
    transition: transform 0.2s, color 0.2s;
  }

  .contact-card:hover .contact-arrow {
    transform: translateX(4px);
    color: var(--accent-cyan);
  }

  .accent-cyan   { color: var(--accent-cyan); }
  .accent-indigo { color: var(--accent-indigo); }
  .accent-purple { color: var(--accent-purple); }

  /* ── Location ─────────────────────────────────────────────── */
  .location-note {
    display: flex;
    align-items: center;
    gap: 8px;
    font-size: 13px;
    color: var(--text-muted);
    padding-left: 4px;
    margin-top: 4px;
  }


  /* ── Footer ───────────────────────────────────────────────── */
  .footer {
    text-align: center;
    font-size: 12px;
    color: var(--text-muted);
    padding-top: 32px;
    border-top: 1px solid var(--border);
    letter-spacing: 0.04em;
  }

  /* ── Responsive ───────────────────────────────────────────── */
  @media (max-width: 900px) {
    .contact-links-col { max-width: 100%; }
  }
</style>

