---

const stats = [
  { value: '2+',  label: 'Years industry exp.' },
  { value: '1',   label: 'Springer Nature publication' },
];
---

<section id="about" class="section">
  <!-- Background accent -->
  <div class="glow-orb glow-indigo" style="width:350px;height:350px;top:50%;right:-80px;transform:translateY(-50%);"></div>

  <div class="container">
    <div class="about-grid">

      <!-- Left: Photo placeholder -->
      <div class="about-photo reveal">
        <div class="photo-frame">
          <img
            src="/profile.jpg"
            alt="Gokulkrishna S"
            class="profile-img"
            onerror="this.style.display='none';this.nextElementSibling.style.display='flex'"
          />
          <div class="photo-placeholder">
            <svg width="56" height="56" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" style="color:var(--text-muted);opacity:0.4">
              <path d="M20 21v-2a4 4 0 00-4-4H8a4 4 0 00-4 4v2"/><circle cx="12" cy="7" r="4"/>
            </svg>
            <span class="font-mono" style="font-size:11px;color:var(--text-muted);margin-top:8px">profile photo</span>
          </div>
        </div>
      </div>

      <!-- Right: Text content -->
      <div class="about-content">
        <p class="section-label reveal">01 — About me</p>
        <h2 class="section-title reveal reveal-delay-1">
          Engineer at the intersection of<br/>
          <span class="gradient-text">robotics & intelligence</span>
        </h2>

        <div class="about-body reveal reveal-delay-2">
          <p>
            I'm an electronics and software engineer currently completing my
            <strong>MSc in Data Science</strong> at the University of Surrey (Distinction track),
            with a foundation in <strong>ECE</strong> and two years of industry experience
            at Ernst & Young GDS.
          </p>
          <p>
            My work is rooted in robotics — I built an autonomous indoor delivery robot
            on <strong>NVIDIA Jetson Nano + ROS</strong> for my undergraduate capstone,
            which led to a <strong>co-authored Springer Nature publication</strong> in 2024.
          </p>
          <p>
            I'm motivated to work in <strong>mobile robotics and autonomous systems</strong>,
            bringing together embedded systems, real-time perception, and data-driven
            intelligence to build robots that operate reliably in the real world.
          </p>
        </div>

        <!-- Stats -->
        <div class="stats-grid reveal reveal-delay-3">
          {stats.map(({ value, label }) => (
            <div class="stat-card">
              <span class="stat-value gradient-text">{value}</span>
              <span class="stat-label">{label}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about-grid {
    display: grid;
    grid-template-columns: 1fr 1.1fr;
    gap: 72px;
    align-items: center;
  }

  /* ── Photo ────────────────────────────────────────────────── */
  .about-photo {
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .photo-frame {
    width: 100%;
    max-width: 420px;
    aspect-ratio: 4/5;
    border-radius: var(--radius-xl);
    overflow: hidden;
    background: linear-gradient(145deg, rgba(255,255,255,0.82), rgba(245,245,247,0.6));
    border: 1px solid rgba(255,255,255,0.9);
    box-shadow: var(--shadow-lg), inset 0 1px 0 rgba(255,255,255,1);
    position: relative;
  }

  .profile-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    transition: transform 0.5s ease;
  }
  .profile-img:hover { transform: scale(1.03); }

  .photo-placeholder {
    position: absolute;
    inset: 0;
    display: none;
    flex-direction: column;
    align-items: center;
    justify-content: center;
  }

  /* ── Text ─────────────────────────────────────────────────── */
  .about-body {
    display: flex;
    flex-direction: column;
    gap: 16px;
    color: var(--text-secondary);
    line-height: 1.8;
    font-size: 15px;
    margin-bottom: 40px;
  }

  .about-body strong { color: var(--text-primary); font-weight: 500; }

  /* ── Stats ────────────────────────────────────────────────── */
  .stats-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
  }

  .stat-card {
    background: var(--bg-card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 20px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    transition: border-color 0.2s, box-shadow 0.2s;
  }

  .stat-card:hover {
    border-color: var(--border-accent);
    box-shadow: var(--shadow-md);
  }

  .stat-value {
    font-family: -apple-system, BlinkMacSystemFont, 'Inter', sans-serif;
    font-size: 28px;
    font-weight: 700;
    letter-spacing: -0.03em;
  }

  .stat-label {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.4;
  }

  /* ── Responsive ───────────────────────────────────────────── */
  @media (max-width: 900px) {
    .about-grid {
      grid-template-columns: 1fr;
      gap: 48px;
    }
    .about-photo { order: 2; }
    .about-content { order: 1; }
  }
</style>
