<section id="certifications" class="section">
  <div class="glow-orb glow-indigo" style="width:300px;height:300px;top:10%;left:-60px;"></div>

  <div class="container">
    <div class="certs-header reveal">
      <p class="section-label">05 — Certifications</p>
      <h2 class="section-title">Credentials & <span class="gradient-text">training</span></h2>
    </div>

    <!-- Featured certifications -->
    <div class="certs-grid">
      {featured.map((cert, i) => {
        const inner = (
          <div class={`cert-card card reveal reveal-delay-${(i % 3) + 1}`}>
            <div class={`cert-icon-wrap accent-bg-${cert.accent}`}>
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class={`accent-${cert.accent}`}>
                <path d={iconPaths[cert.icon]} stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="cert-body">
              <h3 class="cert-title">{cert.title}</h3>
              <div class="cert-meta">
                <p class={`cert-issuer accent-${cert.accent}`}>{cert.issuer}</p>
                {cert.date && <span class="cert-date font-mono">{cert.date}</span>}
              </div>
              <p class="cert-desc">{cert.desc}</p>
            </div>
          </div>
        );
        return cert.href
          ? <a href={cert.href} target="_blank" rel="noopener" class="cert-link">{inner}</a>
          : inner;
      })}
    </div>

    <!-- Show More button -->
    <div class="show-more-wrap reveal">
      <div class="glass-btn-wrap">
        <button class="glass-btn" id="show-certs-btn">
          Show More Certifications
          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M6 9l6 6 6-6"/></svg>
        </button>
        <div class="glass-btn-shadow"></div>
      </div>
    </div>
  </div>
</section>

<!-- Certifications modal -->
<div class="certs-modal" id="certs-modal" aria-hidden="true">
  <div class="certs-modal-backdrop" id="certs-backdrop"></div>
  <div class="certs-modal-panel">
    <div class="modal-header">
      <h3 class="modal-title">All Certifications</h3>
      <button class="modal-close" id="certs-close" aria-label="Close">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M18 6L6 18M6 6l12 12"/></svg>
      </button>
    </div>
    <div class="certs-modal-grid">
      {extra.map((cert, i) => (
        <a href={cert.href} target="_blank" rel="noopener" class="cert-link">
          <div class={`cert-card card`}>
            <div class={`cert-icon-wrap accent-bg-${cert.accent}`}>
              <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" class={`accent-${cert.accent}`}>
                <path d={iconPaths[cert.icon]} stroke-linecap="round" stroke-linejoin="round"/>
              </svg>
            </div>
            <div class="cert-body">
              <h3 class="cert-title">{cert.title}</h3>
              <div class="cert-meta">
                <p class={`cert-issuer accent-${cert.accent}`}>{cert.issuer}</p>
                {cert.date && <span class="cert-date font-mono">{cert.date}</span>}
              </div>
            </div>
          </div>
        </a>
      ))}
    </div>
  </div>
</div>

<style>
  .certs-header { margin-bottom: 48px; }

  .certs-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 20px;
  }

  .cert-link {
    text-decoration: none;
    display: block;
  }

  .cert-card {
    display: flex;
    gap: 16px;
    align-items: flex-start;
    padding: 22px;
    height: 100%;
    transition: all 0.3s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }

  .cert-icon-wrap {
    width: 44px;
    height: 44px;
    flex-shrink: 0;
    border-radius: 10px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .accent-bg-cyan   { background: rgba(0,113,227,0.06);   border: 1px solid rgba(0,113,227,0.18); }
  .accent-bg-indigo { background: rgba(88,86,214,0.06);   border: 1px solid rgba(88,86,214,0.16); }
  .accent-bg-purple { background: rgba(155,89,182,0.06);  border: 1px solid rgba(155,89,182,0.18); }

  .cert-body { flex: 1; min-width: 0; }

  .cert-title {
    font-size: 13px;
    font-weight: 600;
    color: var(--text-primary);
    margin-bottom: 6px;
    line-height: 1.35;
  }

  .cert-meta {
    display: flex;
    align-items: center;
    gap: 8px;
    margin-bottom: 8px;
    flex-wrap: wrap;
  }

  .cert-issuer {
    font-family: 'SF Mono', ui-monospace, monospace;
    font-size: 10px;
    letter-spacing: 0.05em;
  }

  .cert-date {
    font-size: 10px;
    color: var(--text-muted);
    letter-spacing: 0.04em;
  }

  .cert-desc {
    font-size: 12px;
    color: var(--text-muted);
    line-height: 1.55;
  }

  .accent-cyan   { color: var(--accent-cyan); }
  .accent-indigo { color: #5856d6; }
  .accent-purple { color: #9b59b6; }

  /* ── Show More ────────────────────────────────────────────── */
  .show-more-wrap {
    display: flex;
    justify-content: center;
    margin-top: 40px;
  }

  /* ── Modal card (compact) ─────────────────────────────────── */
  #certs-modal .cert-card {
    padding: 18px;
  }

  @media (max-width: 1024px) { .certs-grid { grid-template-columns: repeat(2,1fr); } }
  @media (max-width: 640px)  { .certs-grid { grid-template-columns: 1fr; } }
</style>

<script>
  const modal    = document.getElementById('certs-modal');
  const openBtn  = document.getElementById('show-certs-btn');
  const closeBtn = document.getElementById('certs-close');
  const backdrop = document.getElementById('certs-backdrop');

  function openModal() {
    modal?.classList.add('open');
    modal?.removeAttribute('aria-hidden');
    document.body.style.overflow = 'hidden';
  }
  function closeModal() {
    modal?.classList.remove('open');
    modal?.setAttribute('aria-hidden', 'true');
    document.body.style.overflow = '';
  }

  openBtn?.addEventListener('click', openModal);
  closeBtn?.addEventListener('click', closeModal);
  backdrop?.addEventListener('click', closeModal);
  document.addEventListener('keydown', (e) => { if (e.key === 'Escape') closeModal(); });
</script>
