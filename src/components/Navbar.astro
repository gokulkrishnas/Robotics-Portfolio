---
const navLinks = [
  { label: 'Home',            href: '#home' },
  { label: 'About',           href: '#about' },
  { label: 'Projects',        href: '#projects' },
  { label: 'Experience',      href: '#experience' },
  { label: 'Skills',          href: '#skills' },
  { label: 'Gallery',         href: '#gallery' },
  { label: 'Certifications',  href: '#certifications' },
  { label: 'Contact',         href: '#contact' },
];
---

<nav id="navbar">
  <!-- Logo -->
  <a href="#home" class="nav-logo" aria-label="Home">
    <div class="logo-hex">
      <svg class="logo-hex-svg" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
        <polygon points="22,2 39,11.5 39,32.5 22,42 5,32.5 5,11.5"
          stroke="url(#hexGrad)" stroke-width="1.5" fill="none"/>
        <circle cx="22" cy="11.5" r="1.5" fill="url(#hexGrad)" opacity="0.7"/>
        <circle cx="39" cy="22" r="1.5" fill="url(#hexGrad)" opacity="0.7"/>
        <circle cx="22" cy="32.5" r="1.5" fill="url(#hexGrad)" opacity="0.7"/>
        <circle cx="5" cy="22" r="1.5" fill="url(#hexGrad)" opacity="0.7"/>
        <defs>
          <linearGradient id="hexGrad" x1="0" y1="0" x2="44" y2="44" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#0071e3"/>
            <stop offset="100%" stop-color="#6e6e73"/>
          </linearGradient>
        </defs>
      </svg>
    </div>
    <div class="logo-text-block">
      <span class="logo-initials">GS</span>
      <span class="logo-sub">portfolio</span>
    </div>
  </a>

  <!-- Desktop nav -->
  <ul class="nav-links" id="nav-links">
    {navLinks.map(({ label, href }) => (
      <li>
        <a href={href} class="nav-btn" data-section={href.slice(1)}>
          <span class="nav-btn-face">{label}</span>
        </a>
      </li>
    ))}
  </ul>

  <!-- Mobile hamburger -->
  <button class="hamburger" id="hamburger" aria-label="Toggle menu">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<!-- Mobile drawer -->
<div class="mobile-drawer" id="mobile-drawer">
  <ul>
    {navLinks.map(({ label, href }) => (
      <li>
        <a href={href} class="mobile-nav-link">{label}</a>
      </li>
    ))}
  </ul>
</div>

<style>
  /* ── Navbar — Apple-style liquid glass ─────────────────── */
  nav {
    position: fixed;
    top: 0; left: 0; right: 0;
    z-index: 100;
    height: var(--navbar-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 40px;
    background: rgba(245, 245, 247, 0.80);
    backdrop-filter: saturate(200%) blur(24px);
    -webkit-backdrop-filter: saturate(200%) blur(24px);
    border-bottom: 1px solid rgba(0, 0, 0, 0.08);
    box-shadow: 0 1px 0 rgba(0,0,0,0.04);
  }

  /* ── Logo ───────────────────────────────────────────────── */
  .nav-logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: transform 0.35s ease, opacity 0.2s;
  }
  .nav-logo:hover { transform: scale(1.04); opacity: 0.85; }

  .logo-hex { width: 36px; height: 36px; flex-shrink: 0; }

  .logo-hex-svg {
    width: 100%; height: 100%;
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1), filter 0.3s ease;
    filter: drop-shadow(0 1px 3px rgba(0,113,227,0.2));
  }
  .nav-logo:hover .logo-hex-svg {
    transform: rotate(60deg);
    filter: drop-shadow(0 2px 6px rgba(0,113,227,0.35));
  }

  .logo-text-block { display: flex; flex-direction: column; line-height: 1; gap: 3px; }

  .logo-initials {
    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
    font-size: 17px;
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--text-primary);
  }

  .logo-sub {
    font-family: 'SF Mono', ui-monospace, monospace;
    font-size: 9px;
    letter-spacing: 0.15em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  /* ── Nav links ──────────────────────────────────────────── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 4px;
    list-style: none;
  }

  /* ── Nav buttons — glass style ─────────────────────────── */
  .nav-btn {
    --gb-angle-1: -75deg;
    --gb-angle-2: -45deg;
    position: relative;
    display: inline-flex;
    align-items: center;
    padding: 7px 16px;
    text-decoration: none;
    border-radius: 999vw;
    cursor: pointer;
    z-index: 3;
    background: linear-gradient(-75deg, rgba(255,255,255,0.04), rgba(255,255,255,0.18), rgba(255,255,255,0.04));
    box-shadow:
      inset 0 1px 2px rgba(0,0,0,0.04),
      inset 0 -1px 2px rgba(255,255,255,0.45),
      0 2px 4px -1px rgba(0,0,0,0.1);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    transition: all 350ms cubic-bezier(0.25,1,0.5,1), --gb-angle-1 500ms ease;
  }

  /* Conic border */
  .nav-btn::after {
    content: '';
    position: absolute;
    inset: 0;
    border-radius: 999vw;
    width: calc(100% + 1.5px);
    height: calc(100% + 1.5px);
    top: -0.75px;
    left: -0.75px;
    padding: 1.5px;
    box-sizing: border-box;
    background:
      conic-gradient(from var(--gb-angle-1) at 50% 50%, rgba(0,0,0,0.35), rgba(0,0,0,0) 5% 40%, rgba(0,0,0,0.35) 50%, rgba(0,0,0,0) 60% 95%, rgba(0,0,0,0.35)),
      linear-gradient(180deg, rgba(255,255,255,0.5), rgba(255,255,255,0.5));
    mask: linear-gradient(#000 0 0) content-box, linear-gradient(#000 0 0);
    mask-composite: exclude;
    pointer-events: none;
    transition: --gb-angle-1 500ms ease;
  }

  .nav-btn-face {
    font-family: -apple-system, BlinkMacSystemFont, 'Helvetica Neue', sans-serif;
    font-size: 13px;
    font-weight: 400;
    color: var(--text-secondary);
    transition: color 0.2s ease;
    position: relative;
    z-index: 1;
    letter-spacing: -0.005em;
    text-shadow: 0 1px 2px rgba(0,0,0,0.06);
    user-select: none;
  }

  .nav-btn:hover {
    --gb-angle-1: -125deg;
    transform: scale(0.975);
    box-shadow:
      inset 0 1px 2px rgba(0,0,0,0.04),
      inset 0 -1px 2px rgba(255,255,255,0.45),
      0 1px 2px -1px rgba(0,0,0,0.14);
  }
  .nav-btn:hover .nav-btn-face { color: var(--text-primary); }

  .nav-btn.active {
    --gb-angle-1: -125deg;
    background: linear-gradient(-75deg, rgba(0,113,227,0.06), rgba(0,113,227,0.14), rgba(0,113,227,0.06));
    box-shadow:
      inset 0 1px 2px rgba(0,0,0,0.04),
      inset 0 -1px 2px rgba(255,255,255,0.5),
      0 2px 8px rgba(0,113,227,0.12);
  }
  .nav-btn.active .nav-btn-face { color: var(--accent); font-weight: 500; }

  /* ── Hamburger ──────────────────────────────────────────── */
  .hamburger {
    display: none; flex-direction: column; gap: 5px;
    background: none; border: none; cursor: pointer; padding: 8px;
  }
  .hamburger span {
    display: block; width: 20px; height: 1.5px;
    background: var(--text-primary); border-radius: 2px;
    transition: all 0.3s ease;
  }
  .hamburger.open span:nth-child(1) { transform: translateY(6.5px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-6.5px) rotate(-45deg); }

  /* ── Mobile drawer ──────────────────────────────────────── */
  .mobile-drawer {
    display: none;
    position: fixed;
    top: var(--navbar-h); left: 0; right: 0;
    z-index: 99;
    background: rgba(245,245,247,0.95);
    backdrop-filter: blur(20px);
    border-bottom: 1px solid var(--border);
    padding: 16px 28px 24px;
    transform: translateY(-8px); opacity: 0; pointer-events: none;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .mobile-drawer.open { opacity: 1; transform: translateY(0); pointer-events: all; }
  .mobile-drawer ul { list-style: none; display: flex; flex-direction: column; gap: 2px; }
  .mobile-nav-link {
    display: block; padding: 11px 0;
    font-family: -apple-system, BlinkMacSystemFont, sans-serif;
    font-size: 16px; color: var(--text-secondary); text-decoration: none;
    border-bottom: 1px solid var(--border); transition: color 0.2s;
  }
  .mobile-nav-link:hover { color: var(--accent); }

  @media (max-width: 768px) {
    .nav-links { display: none; }
    .hamburger { display: flex; }
    .mobile-drawer { display: block; }
  }
</style>

<script>
  // ── Active section highlight on scroll ──────────────────────
  const sections = document.querySelectorAll('section[id]');
  const navBtns  = document.querySelectorAll('.nav-btn[data-section]');

  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navBtns.forEach((btn) => {
            btn.classList.toggle('active', btn.getAttribute('data-section') === entry.target.id);
          });
        }
      });
    },
    { rootMargin: '-40% 0px -55% 0px' }
  );

  sections.forEach((s) => sectionObserver.observe(s));

  // ── Mobile hamburger ────────────────────────────────────────
  const hamburger    = document.getElementById('hamburger');
  const mobileDrawer = document.getElementById('mobile-drawer');

  hamburger?.addEventListener('click', () => {
    hamburger.classList.toggle('open');
    mobileDrawer?.classList.toggle('open');
  });

  // Close drawer on link click
  mobileDrawer?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      hamburger?.classList.remove('open');
      mobileDrawer.classList.remove('open');
    });
  });

  // ── Navbar background on scroll ─────────────────────────────
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 20);
  });
</script>
