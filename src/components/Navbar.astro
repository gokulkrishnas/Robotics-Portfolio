---
const navLinks = [
  { label: 'Home',            href: '#home' },
  { label: 'About',           href: '#about' },
  { label: 'Projects',        href: '#projects' },
  { label: 'Experience',      href: '#experience' },
  { label: 'Skills',          href: '#skills' },
  { label: 'Certifications',  href: '#certifications' },
  { label: 'Contact',         href: '#contact' },
];
---

<nav id="navbar">
  <!-- Logo -->
  <a href="#home" class="nav-logo" aria-label="Home">
    <div class="logo-hex">
      <svg class="logo-hex-svg" viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
        <!-- Outer hexagon -->
        <polygon points="22,2 39,11.5 39,32.5 22,42 5,32.5 5,11.5"
          stroke="url(#hexGrad)" stroke-width="1.5" fill="none"/>
        <!-- Inner dots — circuit feel -->
        <circle cx="22" cy="11.5" r="1.5" fill="url(#hexGrad)" opacity="0.7"/>
        <circle cx="39" cy="22" r="1.5" fill="url(#hexGrad)" opacity="0.7"/>
        <circle cx="22" cy="32.5" r="1.5" fill="url(#hexGrad)" opacity="0.7"/>
        <circle cx="5" cy="22" r="1.5" fill="url(#hexGrad)" opacity="0.7"/>
        <defs>
          <linearGradient id="hexGrad" x1="0" y1="0" x2="44" y2="44" gradientUnits="userSpaceOnUse">
            <stop offset="0%" stop-color="#38bdf8"/>
            <stop offset="100%" stop-color="#818cf8"/>
          </linearGradient>
        </defs>
      </svg>
    </div>
    <div class="logo-text-block">
      <span class="logo-initials">GK</span>
      <span class="logo-sub">portfolio</span>
    </div>
  </a>

  <!-- Desktop nav -->
  <ul class="nav-links" id="nav-links">
    {navLinks.map(({ label, href }) => (
      <li>
        <a href={href} class="nav-btn" data-section={href.slice(1)}>
          <span class="nav-btn-face">{label}</span>
        </a>
      </li>
    ))}
  </ul>

  <!-- Mobile hamburger -->
  <button class="hamburger" id="hamburger" aria-label="Toggle menu">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<!-- Mobile drawer -->
<div class="mobile-drawer" id="mobile-drawer">
  <ul>
    {navLinks.map(({ label, href }) => (
      <li>
        <a href={href} class="mobile-nav-link">{label}</a>
      </li>
    ))}
  </ul>
</div>

<style>
  /* ── Navbar shell — liquid glass ───────────────────────── */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--navbar-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 32px;
    /* Liquid glass */
    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.06) 0%,
      rgba(255, 255, 255, 0.02) 100%
    );
    backdrop-filter: blur(48px) saturate(1.8);
    -webkit-backdrop-filter: blur(48px) saturate(1.8);
    border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    box-shadow:
      0 4px 24px rgba(0, 0, 0, 0.25),
      inset 0 1px 0 rgba(255, 255, 255, 0.1);
  }

  /* gradient glow line at bottom */
  nav::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 10%;
    width: 80%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      rgba(56,189,248,0.5),
      rgba(129,140,248,0.5),
      transparent
    );
  }

  /* ── New Logo ───────────────────────────────────────────── */
  .nav-logo {
    text-decoration: none;
    display: flex;
    align-items: center;
    gap: 10px;
    transition: transform 0.35s ease;
  }

  .nav-logo:hover { transform: scale(1.04); }

  /* Hexagon icon */
  .logo-hex {
    width: 36px;
    height: 36px;
    position: relative;
    flex-shrink: 0;
  }

  .logo-hex-svg {
    width: 100%;
    height: 100%;
    transition: transform 0.6s cubic-bezier(0.34, 1.56, 0.64, 1), filter 0.35s ease;
    filter: drop-shadow(0 0 4px rgba(56,189,248,0.3));
  }

  .nav-logo:hover .logo-hex-svg {
    transform: rotate(60deg);
    filter: drop-shadow(0 0 8px rgba(56,189,248,0.6));
  }

  /* Text block */
  .logo-text-block {
    display: flex;
    flex-direction: column;
    line-height: 1;
    gap: 2px;
  }

  .logo-initials {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 16px;
    font-weight: 700;
    letter-spacing: 0.08em;
    background: linear-gradient(135deg, #38bdf8, #818cf8);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
  }

  .logo-sub {
    font-family: 'JetBrains Mono', monospace;
    font-size: 9px;
    letter-spacing: 0.2em;
    color: var(--text-muted);
    text-transform: uppercase;
  }

  /* ── Nav link list ──────────────────────────────────────── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 8px;
    list-style: none;
    /* Perspective plane for the row of buttons */
    transform-style: preserve-3d;
  }

  /* ── Liquid Glass Nav Button ────────────────────────────── */
  .nav-btn {
    position: relative;
    display: inline-block;
    padding: 7px 16px;
    text-decoration: none;
    border-radius: 10px;
    cursor: pointer;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease, border-color 0.2s ease;

    background: linear-gradient(
      135deg,
      rgba(255, 255, 255, 0.07) 0%,
      rgba(255, 255, 255, 0.02) 100%
    );
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    box-shadow:
      0 2px 12px rgba(0, 0, 0, 0.2),
      inset 0 1px 0 rgba(255, 255, 255, 0.14);
  }

  /* Shimmer on hover */
  .nav-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: linear-gradient(105deg, transparent 35%, rgba(255,255,255,0.08) 50%, transparent 65%);
    transform: translateX(-100%);
    transition: transform 0.5s ease;
  }
  .nav-btn:hover::before { transform: translateX(100%); }

  .nav-btn-face {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--text-secondary);
    transition: color 0.2s ease;
    position: relative;
    z-index: 1;
  }

  .nav-btn:hover {
    transform: translateY(-2px);
    border-color: rgba(56, 189, 248, 0.28);
    box-shadow:
      0 6px 20px rgba(0, 0, 0, 0.3),
      0 0 16px rgba(56, 189, 248, 0.1),
      inset 0 1px 0 rgba(255, 255, 255, 0.2);
  }

  .nav-btn:hover .nav-btn-face { color: var(--text-primary); }

  .nav-btn:active { transform: translateY(0); }

  /* Active section */
  .nav-btn.active {
    background: linear-gradient(
      135deg,
      rgba(56, 189, 248, 0.12) 0%,
      rgba(129, 140, 248, 0.06) 100%
    );
    border-color: rgba(56, 189, 248, 0.3);
    box-shadow:
      0 0 20px rgba(56, 189, 248, 0.1),
      inset 0 1px 0 rgba(56, 189, 248, 0.2);
  }

  .nav-btn.active .nav-btn-face { color: var(--accent-cyan); }

  /* ── Hamburger (mobile) ─────────────────────────────────── */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }

  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text-secondary);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── Mobile drawer ──────────────────────────────────────── */
  .mobile-drawer {
    display: none;
    position: fixed;
    top: var(--navbar-h);
    left: 0;
    right: 0;
    z-index: 99;
    background: rgba(5,5,13,0.97);
    backdrop-filter: blur(24px);
    border-bottom: 1px solid var(--border);
    padding: 20px 32px 28px;
    transform: translateY(-8px);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .mobile-drawer.open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }

  .mobile-drawer ul { list-style: none; display: flex; flex-direction: column; gap: 4px; }

  .mobile-nav-link {
    display: block;
    padding: 12px 0;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 16px;
    color: var(--text-secondary);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    transition: color 0.2s;
  }

  .mobile-nav-link:hover { color: var(--accent-cyan); }

  @media (max-width: 768px) {
    .nav-links  { display: none; }
    .hamburger  { display: flex; }
    .mobile-drawer { display: block; }
  }
</style>

<script>
  // ── Active section highlight on scroll ──────────────────────
  const sections = document.querySelectorAll('section[id]');
  const navBtns  = document.querySelectorAll('.nav-btn[data-section]');

  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navBtns.forEach((btn) => {
            btn.classList.toggle('active', btn.getAttribute('data-section') === entry.target.id);
          });
        }
      });
    },
    { rootMargin: '-40% 0px -55% 0px' }
  );

  sections.forEach((s) => sectionObserver.observe(s));

  // ── Mobile hamburger ────────────────────────────────────────
  const hamburger    = document.getElementById('hamburger');
  const mobileDrawer = document.getElementById('mobile-drawer');

  hamburger?.addEventListener('click', () => {
    hamburger.classList.toggle('open');
    mobileDrawer?.classList.toggle('open');
  });

  // Close drawer on link click
  mobileDrawer?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      hamburger?.classList.remove('open');
      mobileDrawer.classList.remove('open');
    });
  });

  // ── Navbar background on scroll ─────────────────────────────
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 20);
  });
</script>
