---
const navLinks = [
  { label: 'Home',            href: '#home' },
  { label: 'About',           href: '#about' },
  { label: 'Projects',        href: '#projects' },
  { label: 'Experience',      href: '#experience' },
  { label: 'Skills',          href: '#skills' },
  { label: 'Certifications',  href: '#certifications' },
  { label: 'Contact',         href: '#contact' },
];
---

<nav id="navbar">
  <!-- Logo -->
  <a href="#home" class="nav-logo" aria-label="Home">
    <span class="logo-bracket">[</span>
    <span class="logo-text">GK</span>
    <span class="logo-bracket">]</span>
  </a>

  <!-- Desktop nav -->
  <ul class="nav-links" id="nav-links">
    {navLinks.map(({ label, href }) => (
      <li>
        <a href={href} class="nav-btn" data-section={href.slice(1)}>
          <span class="nav-btn-face">{label}</span>
        </a>
      </li>
    ))}
  </ul>

  <!-- Mobile hamburger -->
  <button class="hamburger" id="hamburger" aria-label="Toggle menu">
    <span></span>
    <span></span>
    <span></span>
  </button>
</nav>

<!-- Mobile drawer -->
<div class="mobile-drawer" id="mobile-drawer">
  <ul>
    {navLinks.map(({ label, href }) => (
      <li>
        <a href={href} class="mobile-nav-link">{label}</a>
      </li>
    ))}
  </ul>
</div>

<style>
  /* ── Navbar shell ───────────────────────────────────────── */
  nav {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 100;
    height: var(--navbar-h);
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 32px;
    background: rgba(5, 5, 13, 0.75);
    backdrop-filter: blur(24px);
    -webkit-backdrop-filter: blur(24px);
    border-bottom: 1px solid var(--border);
    /* Perspective for 3D child elements */
    perspective: 800px;
  }

  /* subtle glow line at bottom */
  nav::after {
    content: '';
    position: absolute;
    bottom: -1px;
    left: 10%;
    width: 80%;
    height: 1px;
    background: linear-gradient(
      90deg,
      transparent,
      var(--accent-cyan),
      var(--accent-indigo),
      transparent
    );
    opacity: 0.4;
  }

  /* ── Logo ───────────────────────────────────────────────── */
  .nav-logo {
    text-decoration: none;
    font-family: 'JetBrains Mono', monospace;
    font-size: 18px;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 2px;
    /* 3D logo: subtle forward tilt */
    transform: perspective(400px) rotateX(4deg);
    transition: transform 0.3s ease;
  }

  .nav-logo:hover { transform: perspective(400px) rotateX(0deg) scale(1.05); }

  .logo-bracket { color: var(--accent-cyan); }
  .logo-text    { color: var(--text-primary); font-size: 16px; }

  /* ── Nav link list ──────────────────────────────────────── */
  .nav-links {
    display: flex;
    align-items: center;
    gap: 8px;
    list-style: none;
    /* Perspective plane for the row of buttons */
    transform-style: preserve-3d;
  }

  /* ── 3D Nav Button ──────────────────────────────────────── */
  .nav-btn {
    position: relative;
    display: inline-block;
    padding: 8px 16px;
    text-decoration: none;
    border-radius: 8px;
    cursor: pointer;
    transform-style: preserve-3d;
    transform: perspective(200px) translateZ(0);
    transition: transform 0.2s ease, box-shadow 0.2s ease, color 0.2s ease, border-color 0.2s ease;

    /* Button face color */
    background: linear-gradient(160deg, #161628 0%, #0c0c1c 100%);
    border: 1px solid rgba(255, 255, 255, 0.07);

    /* ── 3D illusion: layered shadows ── */
    box-shadow:
      /* bottom-right depth shadow */
      3px 3px 0px #020208,
      /* inner top highlight */
      inset 0 1px 0 rgba(255,255,255,0.07),
      /* outer glow off */
      0 0 0 transparent;
  }

  .nav-btn-face {
    font-family: 'Space Grotesk', sans-serif;
    font-size: 13px;
    font-weight: 500;
    letter-spacing: 0.03em;
    color: var(--text-secondary);
    transition: color 0.2s ease;
    position: relative;
    z-index: 1;
  }

  /* Hover: lift up, glow */
  .nav-btn:hover {
    transform: perspective(200px) translateY(-3px) translateZ(4px);
    border-color: rgba(56,189,248,0.3);
    box-shadow:
      4px 6px 0px #020208,
      inset 0 1px 0 rgba(255,255,255,0.1),
      0 0 18px var(--glow-cyan);
  }

  .nav-btn:hover .nav-btn-face { color: var(--accent-cyan); }

  /* Press */
  .nav-btn:active {
    transform: perspective(200px) translateY(1px) translateZ(-2px);
    box-shadow:
      1px 2px 0px #020208,
      inset 0 2px 4px rgba(0,0,0,0.5);
  }

  /* Active section indicator */
  .nav-btn.active {
    border-color: rgba(56,189,248,0.35);
    box-shadow:
      3px 3px 0px #020208,
      inset 0 1px 0 rgba(255,255,255,0.1),
      0 0 20px var(--glow-cyan),
      inset 0 0 12px rgba(56,189,248,0.06);
  }

  .nav-btn.active .nav-btn-face { color: var(--accent-cyan); }

  /* ── Hamburger (mobile) ─────────────────────────────────── */
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 8px;
  }

  .hamburger span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text-secondary);
    border-radius: 2px;
    transition: all 0.3s ease;
  }

  .hamburger.open span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.open span:nth-child(2) { opacity: 0; }
  .hamburger.open span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }

  /* ── Mobile drawer ──────────────────────────────────────── */
  .mobile-drawer {
    display: none;
    position: fixed;
    top: var(--navbar-h);
    left: 0;
    right: 0;
    z-index: 99;
    background: rgba(5,5,13,0.97);
    backdrop-filter: blur(24px);
    border-bottom: 1px solid var(--border);
    padding: 20px 32px 28px;
    transform: translateY(-8px);
    opacity: 0;
    pointer-events: none;
    transition: transform 0.3s ease, opacity 0.3s ease;
  }

  .mobile-drawer.open {
    opacity: 1;
    transform: translateY(0);
    pointer-events: all;
  }

  .mobile-drawer ul { list-style: none; display: flex; flex-direction: column; gap: 4px; }

  .mobile-nav-link {
    display: block;
    padding: 12px 0;
    font-family: 'Space Grotesk', sans-serif;
    font-size: 16px;
    color: var(--text-secondary);
    text-decoration: none;
    border-bottom: 1px solid var(--border);
    transition: color 0.2s;
  }

  .mobile-nav-link:hover { color: var(--accent-cyan); }

  @media (max-width: 768px) {
    .nav-links  { display: none; }
    .hamburger  { display: flex; }
    .mobile-drawer { display: block; }
  }
</style>

<script>
  // ── Active section highlight on scroll ──────────────────────
  const sections = document.querySelectorAll('section[id]');
  const navBtns  = document.querySelectorAll('.nav-btn[data-section]');

  const sectionObserver = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navBtns.forEach((btn) => {
            btn.classList.toggle('active', btn.getAttribute('data-section') === entry.target.id);
          });
        }
      });
    },
    { rootMargin: '-40% 0px -55% 0px' }
  );

  sections.forEach((s) => sectionObserver.observe(s));

  // ── Mobile hamburger ────────────────────────────────────────
  const hamburger    = document.getElementById('hamburger');
  const mobileDrawer = document.getElementById('mobile-drawer');

  hamburger?.addEventListener('click', () => {
    hamburger.classList.toggle('open');
    mobileDrawer?.classList.toggle('open');
  });

  // Close drawer on link click
  mobileDrawer?.querySelectorAll('a').forEach((link) => {
    link.addEventListener('click', () => {
      hamburger?.classList.remove('open');
      mobileDrawer.classList.remove('open');
    });
  });

  // ── Navbar background on scroll ─────────────────────────────
  const navbar = document.getElementById('navbar');
  window.addEventListener('scroll', () => {
    navbar?.classList.toggle('scrolled', window.scrollY > 20);
  });
</script>
