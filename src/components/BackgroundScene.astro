---
/**
 * BackgroundScene — renders a Spline scene as a fixed full-screen background.
 * Sits behind all content at very low opacity for a subtle ambient effect.
 */
const url = 'https://prod.spline.design/hufbdHr7efd09oJB/scene.splinecode';
---

<div class="bg-scene" aria-hidden="true">
  <canvas id="bg-spline"></canvas>
</div>

<style>
  .bg-scene {
    position: fixed;
    inset: 0;
    z-index: 0;
    pointer-events: none;
    opacity: 0;
    transition: opacity 1.5s ease;
  }

  .bg-scene.loaded { opacity: 0.22; }

  #bg-spline {
    width: 100%;
    height: 100%;
    display: block;
  }

  /* Mask over the Spline watermark (rendered inside canvas, bottom-right) */
  .bg-scene::after {
    content: '';
    position: absolute;
    bottom: 0;
    right: 0;
    width: 180px;
    height: 56px;
    background: var(--bg-base);
    pointer-events: none;
  }
</style>

<script>
  async function initBackground() {
    const { Application } = await import('@splinetool/runtime');
    const canvas = document.getElementById('bg-spline') as HTMLCanvasElement;
    const wrapper = canvas.parentElement!;

    try {
      const app = new Application(canvas);
      await app.load('https://prod.spline.design/hufbdHr7efd09oJB/scene.splinecode');
      // Fade in once loaded
      wrapper.classList.add('loaded');
    } catch {
      // Silently fall back to CSS aurora if scene fails
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initBackground);
  } else {
    initBackground();
  }
</script>
